index 00000000..995960b2
--- /dev/null
+++ b/runtime/web/src/ui/app-timeline-cache.ts
@@ -0,0 +1,186 @@
+type TimelinePayload = {
+  posts?: any[];
+  has_more?: boolean;
+};
+
+type TimelineSnapshot = {
+  posts: any[];
+  has_more: boolean;
+  cachedAt: number;
+};
+
+type StorageLike = {
+  getItem: (key: string) => string | null;
+  setItem: (key: string, value: string) => void;
+  removeItem?: (key: string) => void;
+};
+
+const TIMELINE_CACHE_KEY = 'piclaw.timeline-cache.v1';
+const TIMELINE_CACHE_LIMIT = 24;
+const TIMELINE_CACHE_TTL_MS = 10 * 60 * 1000;
+const timelineCache = new Map<string, TimelineSnapshot>();
+const prewarmInFlight = new Map<string, Promise<void>>();
+
+function nowMs(): number {
+  return Date.now();
+}
+
+function getRuntimeStorage(storage: StorageLike | null | undefined = typeof sessionStorage !== 'undefined' ? sessionStorage : null): StorageLike | null {
+  return storage || null;
+}
+
+function normalizeChatJid(chatJid: string | null | undefined): string {
+  return String(chatJid || '').trim();
+}
+
+function isFresh(snapshot: TimelineSnapshot | null | undefined, maxAgeMs = TIMELINE_CACHE_TTL_MS): snapshot is TimelineSnapshot {
+  return Boolean(snapshot && (nowMs() - snapshot.cachedAt) <= maxAgeMs);
+}
+
+function pruneCacheMap(cache: Map<string, TimelineSnapshot>): void {
+  while (cache.size > TIMELINE_CACHE_LIMIT) {
+    const oldestKey = cache.keys().next().value;
+    if (!oldestKey) break;
+    cache.delete(oldestKey);
+  }
+}
+
+function touchCacheEntry(chatJid: string, snapshot: TimelineSnapshot): TimelineSnapshot {
+  timelineCache.delete(chatJid);
+  timelineCache.set(chatJid, snapshot);
+  pruneCacheMap(timelineCache);
+  return snapshot;
+}
+
+function readPersistentCache(storage: StorageLike | null): Map<string, TimelineSnapshot> {
+  const next = new Map<string, TimelineSnapshot>();
+  if (!storage) return next;
+  try {
+    const raw = storage.getItem(TIMELINE_CACHE_KEY);
+    if (!raw) return next;
+    const parsed = JSON.parse(raw);
+    if (!Array.isArray(parsed)) return next;
+    for (const entry of parsed) {
+      const chatJid = normalizeChatJid(entry?.chatJid);
+      if (!chatJid) continue;
+      const posts = Array.isArray(entry?.snapshot?.posts) ? entry.snapshot.posts : [];
+      const hasMore = Boolean(entry?.snapshot?.has_more);
+      const cachedAt = Number(entry?.snapshot?.cachedAt || 0);
+      if (!Number.isFinite(cachedAt) || cachedAt <= 0) continue;
+      next.set(chatJid, { posts, has_more: hasMore, cachedAt });
+    }
+  } catch {
+    return new Map();
+  }
+  return next;
+}
+
+function writePersistentCache(storage: StorageLike | null): void {
+  if (!storage) return;
+  try {
+    const rows = Array.from(timelineCache.entries()).map(([chatJid, snapshot]) => ({ chatJid, snapshot }));
+    storage.setItem(TIMELINE_CACHE_KEY, JSON.stringify(rows));
+  } catch {
+    // Ignore storage quota/privacy failures.
+  }
+}
+
+export function cacheTimelineSnapshot(
+  chatJid: string | null | undefined,
+  payload: TimelinePayload,
+  storage?: StorageLike | null,
+): TimelineSnapshot | null {
+  const normalizedChatJid = normalizeChatJid(chatJid);
+  if (!normalizedChatJid) return null;
+  const snapshot: TimelineSnapshot = {
+    posts: Array.isArray(payload?.posts) ? payload.posts : [],
+    has_more: Boolean(payload?.has_more),
+    cachedAt: nowMs(),
+  };
+  touchCacheEntry(normalizedChatJid, snapshot);
+  writePersistentCache(getRuntimeStorage(storage));
+  return snapshot;
+}
+
+export function getCachedTimelineSnapshot(
+  chatJid: string | null | undefined,
+  options: { maxAgeMs?: number; storage?: StorageLike | null } = {},
+): TimelineSnapshot | null {
+  const normalizedChatJid = normalizeChatJid(chatJid);
+  if (!normalizedChatJid) return null;
+  const maxAgeMs = Number.isFinite(options.maxAgeMs) ? Number(options.maxAgeMs) : TIMELINE_CACHE_TTL_MS;
+
+  const memorySnapshot = timelineCache.get(normalizedChatJid) || null;
+  if (isFresh(memorySnapshot, maxAgeMs)) {
+    return touchCacheEntry(normalizedChatJid, memorySnapshot);
+  }
+
+  const storage = getRuntimeStorage(options.storage);
+  const persisted = readPersistentCache(storage).get(normalizedChatJid) || null;
+  if (!isFresh(persisted, maxAgeMs)) {
+    return null;
+  }
+  return touchCacheEntry(normalizedChatJid, persisted);
+}
+
+export function resolveRecentTimelinePrewarmChatJids(chats: unknown, currentChatJid: string | null | undefined, limit = 5): string[] {
+  if (!Array.isArray(chats)) return [];
+  const normalizedCurrentChatJid = normalizeChatJid(currentChatJid);
+  const maxRows = Number.isFinite(limit) ? Math.max(1, Math.min(8, Number(limit))) : 5;
+  const seen = new Set<string>();
+  const result: string[] = [];
+  for (const chat of chats) {
+    const chatJid = normalizeChatJid(chat?.chat_jid);
+    if (!chatJid || chatJid === normalizedCurrentChatJid || seen.has(chatJid)) continue;
+    seen.add(chatJid);
+    result.push(chatJid);
+    if (result.length >= maxRows) break;
+  }
+  return result;
+}
+
+export async function prewarmTimelineSnapshots(options: {
+  chatJids: string[];
+  fetchTimeline: (chatJid: string) => Promise<TimelinePayload>;
+  storage?: StorageLike | null;
+  maxAgeMs?: number;
+  maxConcurrent?: number;
+}): Promise<void> {
+  const uniqueChatJids = Array.from(new Set((options.chatJids || []).map((chatJid) => normalizeChatJid(chatJid)).filter(Boolean)));
+  if (uniqueChatJids.length === 0) return;
+  const maxAgeMs = Number.isFinite(options.maxAgeMs) ? Number(options.maxAgeMs) : TIMELINE_CACHE_TTL_MS;
+  const maxConcurrent = Number.isFinite(options.maxConcurrent) ? Math.max(1, Math.min(4, Number(options.maxConcurrent))) : 2;
+  const storage = getRuntimeStorage(options.storage);
+  const pending = uniqueChatJids.filter((chatJid) => !isFresh(getCachedTimelineSnapshot(chatJid, { maxAgeMs, storage }), maxAgeMs));
+  let cursor = 0;
+  const workers = Array.from({ length: Math.min(maxConcurrent, pending.length) }, async () => {
+    while (cursor < pending.length) {
+      const chatJid = pending[cursor++];
+      const existing = prewarmInFlight.get(chatJid);
+      if (existing) {
+        await existing;
+        continue;
+      }
+      const task = (async () => {
+        try {
+          const payload = await options.fetchTimeline(chatJid);
+          cacheTimelineSnapshot(chatJid, payload, storage);
+        } catch {
+          // Best-effort prewarm only.
+        } finally {
+          prewarmInFlight.delete(chatJid);
+        }
+      })();
+      prewarmInFlight.set(chatJid, task);
+      await task;
+    }
+  });
+  await Promise.all(workers);
+}
+
+export function clearTimelineSnapshotCache(storage?: StorageLike | null): void {
+  timelineCache.clear();
+  prewarmInFlight.clear();
+  const runtimeStorage = getRuntimeStorage(storage);
+  runtimeStorage?.removeItem?.(TIMELINE_CACHE_KEY);
+}
