+  let refreshCalls = 0;
+  let getOrCreateCalls = 0;
+
+  const fixture = createFacade({
+    getOrCreateRuntime: async () => {
+      getOrCreateCalls += 1;
+      throw new Error("cold model lookup should not hydrate a runtime");
+    },
+    modelRegistry: {
+      refresh: () => { refreshCalls += 1; },
+      getAvailable: () => [
