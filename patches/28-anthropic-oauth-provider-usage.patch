+    ? overageGrant.currency.trim().toUpperCase()
+    : null;
+
+  if (!enabled && (grantAmountMinorUnits == null || grantAmountMinorUnits <= 0) && (monthlyLimitMinor == null || monthlyLimitMinor === 0)) {
+    return null;
+  }
+
+  const unlimited = enabled && monthlyLimitMinor === null;
+  const usedUsd = usedMinor != null && Number.isFinite(Number(usedMinor)) ? Number(usedMinor) / 100 : null;
+  const monthlyLimitUsd = enabled && !unlimited && monthlyLimitMinor != null && Number.isFinite(Number(monthlyLimitMinor))
