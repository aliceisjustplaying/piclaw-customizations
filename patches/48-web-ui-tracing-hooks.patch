   if (originalWindow === undefined) {
     delete globalThis.window;
   } else {
@@ -38,6 +40,17 @@ test('createSessionFromCompose refreshes branch state and navigates to the new c'
   expect(refreshes.sort()).toEqual(['active', 'branches']);
