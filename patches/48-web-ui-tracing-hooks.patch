 test('invokePaneBeforeDetachFromHost calls the pane detach lifecycle hook when present', async () => {
diff --git a/runtime/test/web/app-window-actions.test.ts b/runtime/test/web/app-window-actions.test.ts
index 87f95a64..8698f2b0 100644
