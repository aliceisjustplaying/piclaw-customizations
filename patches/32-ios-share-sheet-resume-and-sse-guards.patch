+export function bindSseWakeLifecycle({ sse, onWake }, runtime = {}) {
+  const win = runtime.window ?? (typeof window !== 'undefined' ? window : null);
+  const doc = runtime.document ?? (typeof document !== 'undefined' ? document : null);
+  if (!win || !doc || !sse) {
+    return () => {};
