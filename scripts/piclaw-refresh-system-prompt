#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PICLAW_SYSTEM_PROMPT_OUT="${PICLAW_SYSTEM_PROMPT_OUT:-/home/agent/.pi/agent/SYSTEM.md}"

write_system_prompt() {
  local template="${REPO_DIR}/SYSTEM.base.md"
  local out="${PICLAW_SYSTEM_PROMPT_OUT}"
  local pi_bin="${HOME}/.local/bin/pi"
  local bundled_cli="/workspace/src/piclaw-live/node_modules/@mariozechner/pi-coding-agent/dist/cli.js"
  local global_cli="${HOME}/.bun/install/global/node_modules/@mariozechner/pi-coding-agent/dist/cli.js"

  if [ ! -f "${template}" ]; then
    echo "piclaw-refresh-system-prompt: missing template ${template}" >&2
    exit 1
  fi

  mkdir -p "$(dirname "${out}")"
  install -m 0644 "${template}" "${out}"

  mkdir -p "$(dirname "${pi_bin}")"
  rm -f "${pi_bin}"
  cat >"${pi_bin}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

bundled_cli="${bundled_cli}"
global_cli="${global_cli}"

if [ -f "\$bundled_cli" ]; then
  exec node "\$bundled_cli" "\$@"
fi

if [ -f "\$global_cli" ]; then
  exec node "\$global_cli" "\$@"
fi

echo "pi launcher: no pi-coding-agent CLI found in bundled or global locations" >&2
exit 1
EOF
  chmod 0755 "${pi_bin}"

  printf '%s\n' "${out}"
}

if [ "$(id -un)" = "agent" ]; then
  write_system_prompt
  exit 0
fi

command_string="$(declare -f write_system_prompt)
REPO_DIR=$(printf '%q' "${REPO_DIR}")
PICLAW_SYSTEM_PROMPT_OUT=$(printf '%q' "${PICLAW_SYSTEM_PROMPT_OUT}")
write_system_prompt"

exec sudo -u agent -H env \
  PATH="/home/agent/.local/bin:/home/agent/.bun/bin:/usr/local/bin:/run/wrappers/bin:/run/current-system/sw/bin" \
  bash -lc "${command_string}"
