#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PICLAW_LIVE_ROOT="${PICLAW_LIVE_ROOT:-/workspace/src/piclaw-live}"
PICLAW_SYSTEM_PROMPT_OUT="${PICLAW_SYSTEM_PROMPT_OUT:-/home/agent/.pi/agent/SYSTEM.md}"

run_prompt_builder() {
  local cli="${PICLAW_LIVE_ROOT}/node_modules/@mariozechner/pi-coding-agent/dist/cli.js"
  if [ ! -f "${cli}" ]; then
    echo "piclaw-refresh-system-prompt: pi-coding-agent CLI not found at ${cli}" >&2
    exit 1
  fi

  env \
    HOME=/home/agent \
    PICLAW_CUSTOMIZATIONS_DIR="${REPO_DIR}" \
    PICLAW_LIVE_ROOT="${PICLAW_LIVE_ROOT}" \
    PICLAW_SYSTEM_PROMPT_OUT="${PICLAW_SYSTEM_PROMPT_OUT}" \
    node --input-type=module -e '
import { mkdirSync, realpathSync, writeFileSync, symlinkSync, existsSync, readFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { pathToFileURL } from "node:url";
const cli = realpathSync(process.argv[1]);
const pkg = dirname(dirname(cli));
const { buildSystemPrompt } = await import(pathToFileURL(join(pkg, "dist/core/system-prompt.js")).href);
const { createAllToolDefinitions } = await import(pathToFileURL(join(pkg, "dist/core/tools/index.js")).href);
const defs = createAllToolDefinitions(process.cwd());
const names = ["read", "bash", "edit", "write"];
const toolSnippets = Object.fromEntries(names.map((n) => [n, defs[n]?.promptSnippet]).filter(([, v]) => v));
const promptGuidelines = names.flatMap((n) => defs[n]?.promptGuidelines ?? []);
let s = buildSystemPrompt({ selectedTools: names, toolSnippets, promptGuidelines, cwd: process.cwd() })
  .replace(/\nCurrent date:.*\nCurrent working directory:.*$/s, "")
  .replace("Pi documentation (read only when the user asks about pi itself, its SDK, extensions, themes, skills, or TUI):", "Pi documentation (read this only for pi-specific questions):");

const overlayPaths = [
  join(process.env.PICLAW_CUSTOMIZATIONS_DIR, "SYSTEM.append.md"),
  join(process.env.HOME, ".pi/agent/SYSTEM.local.md"),
  "/workspace/.pi/SYSTEM.local.md",
];

for (const path of overlayPaths) {
  if (!existsSync(path)) continue;
  const content = readFileSync(path, "utf-8").trim();
  if (!content) continue;
  s += `\n\n---\n\n${content}`;
}

const out = process.env.PICLAW_SYSTEM_PROMPT_OUT || join(process.env.HOME, ".pi/agent/SYSTEM.md");
mkdirSync(dirname(out), { recursive: true });
writeFileSync(out, s + "\n");
const piBin = join(process.env.HOME, ".local/bin/pi");
mkdirSync(dirname(piBin), { recursive: true });
if (!existsSync(piBin)) symlinkSync(join(pkg, "dist/cli.js"), piBin);
console.log(out);
' "$cli"
}

if [ "$(id -un)" = "agent" ]; then
  run_prompt_builder
  exit 0
fi

command_string="$(declare -f run_prompt_builder)
REPO_DIR=$(printf '%q' "${REPO_DIR}")
PICLAW_LIVE_ROOT=$(printf '%q' "${PICLAW_LIVE_ROOT}")
PICLAW_SYSTEM_PROMPT_OUT=$(printf '%q' "${PICLAW_SYSTEM_PROMPT_OUT}")
run_prompt_builder"

exec sudo -u agent -H env \
  PATH="/home/agent/.local/bin:/home/agent/.bun/bin:/usr/local/bin:/run/wrappers/bin:/run/current-system/sw/bin" \
  bash -lc "${command_string}"
